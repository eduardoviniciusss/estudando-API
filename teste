add.MapGet("/bebidas/{id}" async ,async (int id,AppDbContext db) => 
{
    var bebida = await db.Bebidas.FindAsync(id);
    return bebida;
});

app.MapPost("/bebidas", async (AppDbContext db,Bebida novaBebida) =>
{
    db.Bebidas.Add(novaBebida);
    await db.SaveChangesAsync();
    return Results.Created($"A bebida {novaBebida} foi criada",novaBebida);
});